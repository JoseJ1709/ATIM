# ===================================
# ATIM - Variables de Entorno (EJEMPLO)
# Copiar como .env y cambiar los valores
# ===================================

APP_NAME=ATIM
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true

HOST=0.0.0.0
PORT=8000

ORTHANC_HOST=orthanc
ORTHANC_HTTP_PORT=8042
ORTHANC_DICOM_PORT=4242
ORTHANC_USERNAME=CAMBIAR_USUARIO
ORTHANC_PASSWORD=CAMBIAR_PASSWORD
ORTHANC_USE_DICOMWEB=true

JOEYCARE_HOST=host.docker.internal
JOEYCARE_PORT=4000
JOEYCARE_UPLOAD_ENDPOINT=/api/upload

SECRET_KEY=CAMBIAR-CLAVE-JWT-PRODUCCION
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

AES_ENCRYPTION_KEY=CAMBIAR_CLAVE_32_BYTES_AES256!!

API_KEY_ATIM=CAMBIAR-API-KEY-PRODUCCION

RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_UPLOAD_PER_MINUTE=20